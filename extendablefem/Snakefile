import json
import os

rule all:
    input:
        "solution_field_data.zip",
        "solution_metrics.json"

rule create_mesh:    
    input:
        script = "create_mesh.py",
        parameters = workflow.configfiles[0],
    output:
        mesh = "mesh.msh",
    conda: "environment_mesh.yml"
    shell:
        """
        python3 {input.script} --input_parameter_file {input.parameters} --output_mesh_file {output.mesh}
        """

rule setup_julia_environment:
    input: "Project.toml"
    output: manifest= "Manifest.toml"
    singularity: "docker://julia:1.12.2-bookworm"
    shell: 
        """
        julia --project=. -e 'using Pkg;Pkg.instantiate()'
        """

rule run_extendablefem_simulation:
    input: 
        parameters = workflow.configfiles[0],
        mesh = "mesh.msh",
        manifest = "Manifest.toml",
    output:
        zip = "solution_field_data.zip",
        metrics = "solution_metrics.json",
    singularity: "docker://julia:1.12.2-bookworm"
    shell:
        """
        julia --project=. run_extendablefem_simulation.jl --configfile {input.parameters} --meshfile {input.mesh} --outputzip {output.zip} --outputmetrics {output.metrics}
        """

